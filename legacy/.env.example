# Google Sheets API Configuration (Server-side only - NO VITE_ prefix)
# SECURITY: These credentials are server-side only and NOT exposed to browser
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SHEETS_NAME=Early Access Applications
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY_ID=your_private_key_id_here
GOOGLE_SERVICE_ACCOUNT_CLIENT_ID=your_client_id_here
GOOGLE_SERVICE_ACCOUNT_PROJECT_ID=your-project-id

# Business Configuration
VITE_COMPANY_NAME=Your Company Name
VITE_COMPANY_TAGLINE=Your Company Tagline
VITE_FUNDING_TARGET=$800K - $10M
VITE_CURRENT_FUNDING=$0
VITE_SUPPORT_EMAIL=hello@yourcompany.com
VITE_COMPANY_LOCATION=Your Location

# Crypto Wallet Configuration
VITE_SOLANA_WALLET_ADDRESS=your_solana_wallet_address_here

# Server Configuration
PORT=3000

# Image Processing Configuration
VITE_IMAGE_MAX_SIZE=800
VITE_IMAGE_QUALITY=0.7
VITE_COPY_FEEDBACK_TIMEOUT=2000
